<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/obsidian_black"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        tools:context=".ui.AuthActivity">

        <!-- HEADER -->
        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginTop="48dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ESTACIÓN AMBIENTAL"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.15" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Portal de Acceso"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

            <View
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:layout_marginTop="16dp"
                android:background="@color/accent_mint" />
        </LinearLayout>

        <!-- AUTH CARD -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAuth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            app:cardBackgroundColor="@color/charcoal_card"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/headerLayout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- EMAIL FIELD -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CORREO ELECTRÓNICO"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:hintEnabled="false"
                    app:boxStrokeColor="@color/card_border"
                    app:boxStrokeWidth="1dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="@string/hint_email"
                        android:textColorHint="#444446"
                        android:textColor="@color/text_primary"
                        android:inputType="textEmailAddress"
                        android:textSize="14sp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:gravity="center_vertical" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- PASSWORD FIELD -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONTRASEÑA"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:hintEnabled="false"
                    app:passwordToggleEnabled="true"
                    app:passwordToggleTint="@color/text_secondary"
                    app:boxStrokeColor="@color/card_border"
                    app:boxStrokeWidth="1dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="@string/hint_password"
                        android:textColorHint="#444446"
                        android:textColor="@color/text_primary"
                        android:inputType="textPassword"
                        android:textSize="14sp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:gravity="center_vertical" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- LOGIN BUTTON -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="@string/button_login"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    app:backgroundTint="@color/accent_mint"
                    app:cornerRadius="12dp"
                    android:layout_marginBottom="12dp"
                    android:letterSpacing="0.02" />

                <!-- REGISTER BUTTON -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRegister"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="@string/button_register"
                    android:textColor="@color/white_soft"
                    app:strokeColor="@color/card_border"
                    app:cornerRadius="12dp"
                    android:letterSpacing="0.02" />

                <!-- SEPARATOR -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="20dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/card_border" />

                    <TextView
                        android:id="@+id/orSeparator"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/text_or"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/card_border" />
                </LinearLayout>

                <!-- GOOGLE SIGN IN BUTTON -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGoogleSignIn"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="@string/button_google_signin"
                    android:textColor="@color/text_primary"
                    android:drawableStart="@drawable/ic_google_logo"
                    android:drawablePadding="12dp"
                    app:strokeColor="@color/card_border"
                    app:cornerRadius="12dp"
                    app:backgroundTint="#05FFFFFF"
                    android:letterSpacing="0.02" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- TERMINAL CONSOLE STATUS -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardConsole"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#050506"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/cardAuth"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONSOLA DE LOGS DEL SISTEMA"
                    android:textColor="#3A3A3C"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/status_auth_initial"
                    android:textColor="@color/accent_mint"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>