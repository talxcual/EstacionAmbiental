<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Capa exterior: Brillo suave y ancho -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="8dp"/>
            <solid android:color="#00000000" />
            <stroke
                android:width="4dp"
                android:color="#22DEFF9A"/>
        </shape>
    </item>

    <!-- Capa media: Brillo medio -->
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp"/>
            <solid android:color="#00000000" />
            <stroke
                android:width="2dp"
                android:color="#66DEFF9A"/>
        </shape>
    </item>

    <!-- Capa interior: Núcleo brillante y delgado -->
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp"/>
            <solid android:color="#1A1A1A" />
            <stroke
                android:width="1dp"
                android:color="#FFDEFF9A"/>
        </shape>
    </item>
</layer-list>
